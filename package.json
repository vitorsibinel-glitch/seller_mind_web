{
  "name": "omniseller",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "build:landing": "turbo build --filter=omniseller-landing",
    "build:web": "turbo build --filter=omniseller-web",
    "build:worker": "turbo build --filter=omniseller-worker",
    "docker:build:landing": "docker build -f apps/landing/Dockerfile -t omniseller-landing .",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t omniseller-web .",
    "docker:build": "npm run docker:build:landing && npm run docker:build:web",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.5.1",
    "turbo": "^2.4.2",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "recharts": "2.15.4",
    "sonner": "^2.0.6",
    "zod": "^3.24.2"
  }
}
